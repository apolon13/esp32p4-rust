// JC1060P470C_I_W_Y — 7" IPS 1024×600  |  Security Control Centre
import { WifiScreen, NetworkInfo }           from "wifi_screen.slint";
import { RcDevicesScreen, RcDeviceInfo }     from "rc_devices_screen.slint";
import { LogScreen, LogEntry }               from "log_screen.slint";
import { MqttScreen }                        from "mqtt_screen.slint";
import { LockScreen }                        from "lock_screen.slint";
import { SettingsScreen }                    from "settings_screen.slint";
import { SimScreen }                         from "sim_screen.slint";

export { NetworkInfo }
export { RcDeviceInfo }
export { LogEntry }

export component AppWindow inherits Window {
    width:      1024px;
    height:      600px;
    background: #0d1117;

    property <int> current-screen: 0;

    // ── WiFi state ───────────────────────────────────────────────
    in-out property <[NetworkInfo]> wifi-networks;
    in-out property <int>           wifi-selected-index: -1;
    in-out property <string>        wifi-status: "Инициализация Wi-Fi...";
    in-out property <string>        wifi-password;
    in-out property <bool>          wifi-ready: false;
    in-out property <bool>          wifi-scanning: false;
    in-out property <bool>          wifi-connecting: false;
    in-out property <bool>          wifi-is-connected: false;
    in-out property <string>        wifi-connected-ssid: "";
    in-out property <string>        wifi-connected-ip: "";

    callback wifi-scan-requested();
    callback wifi-connect-requested(string, string);
    callback wifi-cancel-connect();
    callback wifi-disconnect();
    callback wifi-password-delete-last();

    // ── RC Devices state ─────────────────────────────────────────
    in-out property <[RcDeviceInfo]> rc-devices;
    in-out property <bool>           rc-scanning: false;
    in-out property <bool>           rc-show-form: false;
    in-out property <int>            rc-edit-id: 0;
    in-out property <string>         rc-device-name;
    in-out property <string>         rc-device-type;
    in-out property <string>         rc-code-hex;
    in-out property <string>         rc-protocol;
    in-out property <int>            rc-bit-count: 0;

    // ── RC Binding state ─────────────────────────────────────────
    in-out property <bool>   rc-binding-active: false;
    in-out property <int>    rc-binding-device-id: 0;
    in-out property <string> rc-binding-device-name;
    in-out property <int>    rc-binding-button-idx: 0;
    in-out property <string> rc-binding-btn-code-0;
    in-out property <string> rc-binding-btn-code-1;
    in-out property <string> rc-binding-btn-code-2;
    in-out property <string> rc-binding-btn-code-3;

    callback rc-scan-start();
    callback rc-scan-cancel();
    callback rc-device-save(int, string, string);
    callback rc-device-delete(int);
    callback rc-device-name-delete-last();
    callback rc-binding-load-codes(int);

    // ── Log state ────────────────────────────────────────────────
    in-out property <[LogEntry]> log-entries;
    in-out property <int>        log-scroll-to: -1;
    in-out property <bool>       log-pinned: false;

    callback log-scroll-end();
    callback log-scroll-start();
    callback log-toggle-pin();

    // ── MQTT state ───────────────────────────────────────────────
    in-out property <string> mqtt-host: "";
    in-out property <string> mqtt-port: "1883";
    in-out property <string> mqtt-username: "";
    in-out property <string> mqtt-password: "";
    in-out property <string> mqtt-client-id: "";
    in-out property <string> mqtt-topic-arm: "security/arm";
    in-out property <string> mqtt-topic-disarm: "security/disarm";
    in-out property <string> mqtt-topic-silent: "security/silent";
    in-out property <string> mqtt-topic-alarm: "security/alarm";
    in-out property <string> mqtt-topic-events: "security/events";
    in-out property <bool>   mqtt-connecting: false;
    in-out property <bool>   mqtt-is-connected: false;
    in-out property <string> mqtt-status: "Не подключено";
    in-out property <string> mqtt-editing-text: "";

    callback mqtt-connect-requested();
    callback mqtt-cancel-connect();
    callback mqtt-disconnect();
    callback mqtt-field-set(int, string);
    callback mqtt-editing-delete-last();

    // ── Security state ───────────────────────────────────────────
    in-out property <bool>   security-armed: false;
    in-out property <bool>   security-alarm: false;
    in-out property <bool>   ui-locked: false;
    in-out property <string> lock-pin-display: "";
    in-out property <bool>   lock-pin-error: false;

    callback lock-pin-digit(string);
    callback lock-pin-delete();
    callback lock-pin-confirm();
    callback arm-now();
    callback lock-screen();

    // ── Settings state ───────────────────────────────────────────
    in-out property <string> settings-pin: "";
    in-out property <string> settings-editing-text: "";

    callback settings-save-pin(string);
    callback settings-editing-delete-last();

    // ── SIM state ────────────────────────────────────────────────
    in-out property <string>   sim-msisdn:       "—";
    in-out property <string>   sim-signal:       "—";
    in-out property <string>   sim-reg:          "—";
    in-out property <string>   sim-cpin:         "—";
    in-out property <[string]> sim-whitelist;
    in-out property <string>   sim-editing-text: "";

    callback sim-whitelist-add(string);
    callback sim-whitelist-remove(int);
    callback sim-editing-delete-last();

    HorizontalLayout {
        // ── Sidebar ──────────────────────────────────────────────
        Rectangle {
            width:        56px;
            background:   #010409;
            border-width: 0;

            Rectangle {
                x:          55px;
                width:      1px;
                background: #21262d;
            }

            VerticalLayout {
                padding:   6px;
                spacing:   4px;
                alignment: start;

                for item[idx] in [
                    { label: "WiFi" },
                    { label: "RF"   },
                    { label: "Лог"  },
                    { label: "MQTT" },
                    { label: "SIM"  },
                    { label: "Наст" },
                ]: Rectangle {
                    height:        44px;
                    background:    root.current-screen == idx ? #1c2128 : transparent;
                    border-radius: 8px;

                    Text {
                        text:                 item.label;
                        font-size:            11px;
                        color:                root.current-screen == idx ? #58a6ff : #484f58;
                        horizontal-alignment: center;
                        vertical-alignment:   center;
                    }
                    TouchArea { clicked => { root.current-screen = idx; } }
                }
            }

            // ── ARM кнопка (снизу) ───────────────────────────────
            // ── Кнопка блокировки экрана ─────────────────────────
            if !root.security-armed && !root.security-alarm && !root.ui-locked: Rectangle {
                y: parent.height - 108px;
                height: 46px;
                x: 5px; width: parent.width - 10px;
                background: lock-ta.has-hover ? #1f6feb : #1158c7;
                border-radius: 8px;
                animate background { duration: 100ms; }
                Text {
                    text: "LOCK";
                    color: #ffffff; font-size: 11px; font-weight: 700;
                    horizontal-alignment: center; vertical-alignment: center;
                }
                lock-ta := TouchArea { clicked => { root.lock-screen(); } }
            }

            // ── Кнопка постановки на охрану ───────────────────────
            if !root.security-armed && !root.security-alarm: Rectangle {
                y: parent.height - 56px;
                height: 46px;
                x: 5px; width: parent.width - 10px;
                background: arm-ta.has-hover ? #2ea043 : #238636;
                border-radius: 8px;
                animate background { duration: 100ms; }
                Text {
                    text: "ARM";
                    color: #ffffff; font-size: 11px; font-weight: 700;
                    horizontal-alignment: center; vertical-alignment: center;
                }
                arm-ta := TouchArea { clicked => { root.arm-now(); } }
            }
        }

        // ── Content area ─────────────────────────────────────────
        Rectangle {
            horizontal-stretch: 1;

            WifiScreen {
                visible:           root.current-screen == 0;
                width:             parent.width;
                height:            parent.height;
                networks         <=> root.wifi-networks;
                selected-index   <=> root.wifi-selected-index;
                status           <=> root.wifi-status;
                password         <=> root.wifi-password;
                ready            <=> root.wifi-ready;
                scanning         <=> root.wifi-scanning;
                connecting       <=> root.wifi-connecting;
                is-connected     <=> root.wifi-is-connected;
                connected-ssid   <=> root.wifi-connected-ssid;
                connected-ip     <=> root.wifi-connected-ip;
                scan-requested               => { root.wifi-scan-requested(); }
                connect-requested(ssid, pwd) => { root.wifi-connect-requested(ssid, pwd); }
                cancel-connect               => { root.wifi-cancel-connect(); }
                disconnect                   => { root.wifi-disconnect(); }
                password-delete-last         => { root.wifi-password-delete-last(); }
            }

            RcDevicesScreen {
                visible:             root.current-screen == 1;
                width:               parent.width;
                height:              parent.height;
                devices            <=> root.rc-devices;
                scanning           <=> root.rc-scanning;
                show-form          <=> root.rc-show-form;
                edit-id            <=> root.rc-edit-id;
                device-name        <=> root.rc-device-name;
                device-type        <=> root.rc-device-type;
                code-hex           <=> root.rc-code-hex;
                protocol           <=> root.rc-protocol;
                bit-count          <=> root.rc-bit-count;
                binding-active      <=> root.rc-binding-active;
                binding-device-id   <=> root.rc-binding-device-id;
                binding-device-name <=> root.rc-binding-device-name;
                binding-button-idx  <=> root.rc-binding-button-idx;
                binding-btn-code-0  <=> root.rc-binding-btn-code-0;
                binding-btn-code-1  <=> root.rc-binding-btn-code-1;
                binding-btn-code-2  <=> root.rc-binding-btn-code-2;
                binding-btn-code-3  <=> root.rc-binding-btn-code-3;
                scan-start                  => { root.rc-scan-start(); }
                scan-cancel                 => { root.rc-scan-cancel(); }
                device-save(id, name, t)    => { root.rc-device-save(id, name, t); }
                device-delete(id)           => { root.rc-device-delete(id); }
                device-name-delete-last     => { root.rc-device-name-delete-last(); }
                binding-load-codes(id)      => { root.rc-binding-load-codes(id); }
            }

            LogScreen {
                visible:      root.current-screen == 2;
                width:        parent.width;
                height:       parent.height;
                entries     <=> root.log-entries;
                scroll-to   <=> root.log-scroll-to;
                pinned      <=> root.log-pinned;
                scroll-end   => { root.log-scroll-end(); }
                scroll-start => { root.log-scroll-start(); }
                toggle-pin   => { root.log-toggle-pin(); }
            }

            MqttScreen {
                visible:       root.current-screen == 3;
                width:         parent.width;
                height:        parent.height;
                wifi-connected: root.wifi-is-connected;
                host          <=> root.mqtt-host;
                port          <=> root.mqtt-port;
                topic-arm     <=> root.mqtt-topic-arm;
                topic-disarm  <=> root.mqtt-topic-disarm;
                topic-silent  <=> root.mqtt-topic-silent;
                topic-alarm   <=> root.mqtt-topic-alarm;
                topic-events  <=> root.mqtt-topic-events;
                connecting    <=> root.mqtt-connecting;
                is-connected  <=> root.mqtt-is-connected;
                status        <=> root.mqtt-status;
                username      <=> root.mqtt-username;
                password      <=> root.mqtt-password;
                client-id     <=> root.mqtt-client-id;
                editing-text  <=> root.mqtt-editing-text;
                connect-requested       => { root.mqtt-connect-requested(); }
                cancel-connect          => { root.mqtt-cancel-connect(); }
                disconnect              => { root.mqtt-disconnect(); }
                field-set(f, v)         => { root.mqtt-field-set(f, v); }
                editing-delete-last     => { root.mqtt-editing-delete-last(); }
            }

            SimScreen {
                visible:              root.current-screen == 4;
                width:                parent.width;
                height:               parent.height;
                msisdn            <=> root.sim-msisdn;
                signal            <=> root.sim-signal;
                reg               <=> root.sim-reg;
                cpin              <=> root.sim-cpin;
                whitelist         <=> root.sim-whitelist;
                editing-text      <=> root.sim-editing-text;
                whitelist-add(n)      => { root.sim-whitelist-add(n); }
                whitelist-remove(i)   => { root.sim-whitelist-remove(i); }
                editing-delete-last   => { root.sim-editing-delete-last(); }
            }

            SettingsScreen {
                visible:              root.current-screen == 5;
                width:                parent.width;
                height:               parent.height;
                pin               <=> root.settings-pin;
                editing-text      <=> root.settings-editing-text;
                save-pin(p)           => { root.settings-save-pin(p); }
                editing-delete-last   => { root.settings-editing-delete-last(); }
            }
        }
    }

    // ── Lock screen overlay (поверх всего) ───────────────────────
    if root.security-armed || root.security-alarm || root.ui-locked: LockScreen {
        x: 0; y: 0;
        width: root.width; height: root.height;
        alarm:       root.security-alarm;
        ui-lock:     root.ui-locked && !root.security-armed && !root.security-alarm;
        has-pin:     root.settings-pin != "";
        pin-display: root.lock-pin-display;
        pin-error:   root.lock-pin-error;
        pin-digit(d)  => { root.lock-pin-digit(d); }
        pin-delete    => { root.lock-pin-delete(); }
        pin-confirm   => { root.lock-pin-confirm(); }
    }
}
