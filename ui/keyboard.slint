// On-screen virtual keyboard for embedded touch UI
// Supports Latin (EN) and Russian (RU / ЙЦУКЕН) layouts.

struct KeyDef {
    lo: string,  // normal label
    hi: string,  // shifted label
}

component Key {
    in property <string> label;
    in property <length>  key-height: 40px;
    in property <bool>    accent:     false;
    callback pressed(string);

    horizontal-stretch: 1;
    height: key-height;

    ta := TouchArea {
        clicked => { root.pressed(root.label); }
    }
    bg := Rectangle {
        background:    accent
                           ? (ta.pressed ? #388bfd : #1f6feb)
                           : (ta.pressed ? #2d333b : #21262d);
        border-radius: 5px;
        border-width:  1px;
        border-color:  #30363d;
    }
    Text {
        text:                 label;
        color:                #e6edf3;
        font-size:            15px;
        horizontal-alignment: center;
        vertical-alignment:   center;
    }
}

component KeyRow {
    in property <[KeyDef]> keys;
    in property <bool>     shift: false;
    callback pressed(string);

    HorizontalLayout {
        spacing: 3px;
        for k in keys: Key {
            label:      shift ? k.hi : k.lo;
            pressed(v) => { root.pressed(v); }
        }
    }
}

export component VirtualKeyboard {
    in-out property <string> value;
    in-out property <bool>   shift:   false;
    in-out property <bool>   lang-ru: false;
    callback done();
    callback delete-last();  // UTF-8 slicing handled by Rust

    height: 228px;

    VerticalLayout {
        spacing: 3px;

        // ── Row 0: digits (same for both layouts) ────────────────────
        KeyRow {
            shift: root.shift;
            keys: [
                {lo:"1",hi:"!"},{lo:"2",hi:"@"},{lo:"3",hi:"#"},
                {lo:"4",hi:"$"},{lo:"5",hi:"%"},{lo:"6",hi:"^"},
                {lo:"7",hi:"&"},{lo:"8",hi:"*"},{lo:"9",hi:"("},
                {lo:"0",hi:")"},
            ];
            pressed(v) => { root.value += v; }
        }

        // ── Rows 1–3: Latin ──────────────────────────────────────────
        if !root.lang-ru: KeyRow {
            shift: root.shift;
            keys: [
                {lo:"q",hi:"Q"},{lo:"w",hi:"W"},{lo:"e",hi:"E"},
                {lo:"r",hi:"R"},{lo:"t",hi:"T"},{lo:"y",hi:"Y"},
                {lo:"u",hi:"U"},{lo:"i",hi:"I"},{lo:"o",hi:"O"},
                {lo:"p",hi:"P"},
            ];
            pressed(v) => { root.value += v; }
        }
        if !root.lang-ru: KeyRow {
            shift: root.shift;
            keys: [
                {lo:"a",hi:"A"},{lo:"s",hi:"S"},{lo:"d",hi:"D"},
                {lo:"f",hi:"F"},{lo:"g",hi:"G"},{lo:"h",hi:"H"},
                {lo:"j",hi:"J"},{lo:"k",hi:"K"},{lo:"l",hi:"L"},
                {lo:"-",hi:"_"},
            ];
            pressed(v) => { root.value += v; }
        }
        if !root.lang-ru: KeyRow {
            shift: root.shift;
            keys: [
                {lo:"z",hi:"Z"},{lo:"x",hi:"X"},{lo:"c",hi:"C"},
                {lo:"v",hi:"V"},{lo:"b",hi:"B"},{lo:"n",hi:"N"},
                {lo:"m",hi:"M"},{lo:".",hi:":"},{lo:"@",hi:"+"},
            ];
            pressed(v) => { root.value += v; }
        }

        // ── Rows 1–3: Russian ЙЦУКЕН ──────────────────────────────────
        if root.lang-ru: KeyRow {
            shift: root.shift;
            keys: [
                {lo:"й",hi:"Й"},{lo:"ц",hi:"Ц"},{lo:"у",hi:"У"},
                {lo:"к",hi:"К"},{lo:"е",hi:"Е"},{lo:"н",hi:"Н"},
                {lo:"г",hi:"Г"},{lo:"ш",hi:"Ш"},{lo:"щ",hi:"Щ"},
                {lo:"з",hi:"З"},
            ];
            pressed(v) => { root.value += v; }
        }
        if root.lang-ru: KeyRow {
            shift: root.shift;
            keys: [
                {lo:"ф",hi:"Ф"},{lo:"ы",hi:"Ы"},{lo:"в",hi:"В"},
                {lo:"а",hi:"А"},{lo:"п",hi:"П"},{lo:"р",hi:"Р"},
                {lo:"о",hi:"О"},{lo:"л",hi:"Л"},{lo:"д",hi:"Д"},
                {lo:"ж",hi:"Ж"},
            ];
            pressed(v) => { root.value += v; }
        }
        if root.lang-ru: KeyRow {
            shift: root.shift;
            keys: [
                {lo:"я",hi:"Я"},{lo:"ч",hi:"Ч"},{lo:"с",hi:"С"},
                {lo:"м",hi:"М"},{lo:"и",hi:"И"},{lo:"т",hi:"Т"},
                {lo:"ь",hi:"Ь"},{lo:"б",hi:"Б"},{lo:"ю",hi:"Ю"},
                {lo:".",hi:"-"},
            ];
            pressed(v) => { root.value += v; }
        }

        // ── Row 4: Shift / Lang / Space / Del ────────────────────────
        HorizontalLayout {
            spacing: 3px;

            Key {
                label:              root.shift ? "SHF*" : "SHF";
                horizontal-stretch: 1;
                accent:             root.shift;
                pressed(_) => { root.shift = !root.shift; }
            }
            Key {
                label:              root.lang-ru ? "EN" : "RU";
                horizontal-stretch: 1;
                accent:             root.lang-ru;
                pressed(_) => { root.lang-ru = !root.lang-ru; }
            }
            Key {
                label:              " ";
                horizontal-stretch: 4;
                pressed(_) => { root.value += " "; }
            }
            Key {
                label:              "DEL";
                horizontal-stretch: 1;
                accent:             true;
                pressed(_) => { root.delete-last(); }
            }
        }

        // ── Row 5: Done ───────────────────────────────────────────────
        HorizontalLayout {
            Key {
                label:      "ГОТОВО";
                key-height: 40px;
                accent:     true;
                pressed(_) => { root.done(); }
            }
        }
    }
}
