import { VirtualKeyboard } from "keyboard.slint";

// ── Settings screen ───────────────────────────────────────────────────────────
export component SettingsScreen {
    in-out property <string> pin;
    in-out property <string> editing-text;

    callback save-pin(string);
    callback editing-delete-last();

    property <bool> pin-active: false;

    // ── Header ────────────────────────────────────────────────────
    Rectangle {
        y: 0; height: 56px; background: #161b22;
        HorizontalLayout {
            padding-left: 20px; padding-right: 20px;
            Text {
                text: "НАСТРОЙКИ"; color: #e6edf3;
                font-size: 20px; font-weight: 700; vertical-alignment: center;
            }
        }
    }

    // ── Content ───────────────────────────────────────────────────
    content := Rectangle {
        y: 56px;
        height: parent.height - 56px;
        clip: true;

        Flickable {
            y: 0; width: parent.width;
            height: root.pin-active ? content.height - 258px : content.height;
            interactive: true;
            viewport-width: self.width;
            viewport-height: 300px;

            VerticalLayout {
                padding: 16px; spacing: 8px; alignment: start;

                Rectangle { height: 8px; }
                Text { text: "БЕЗОПАСНОСТЬ"; color: #484f58; font-size: 11px; letter-spacing: 0.8px; }

                // PIN поле
                HorizontalLayout {
                    height: 44px; spacing: 8px;
                    Text {
                        text: "PIN-код"; color: #8b949e; font-size: 13px;
                        vertical-alignment: center; width: 100px;
                    }
                    Rectangle {
                        horizontal-stretch: 1;
                        background: #0d1117; border-radius: 6px; border-width: 1px;
                        border-color: root.pin-active ? #f0883e : #30363d;
                        animate border-color { duration: 100ms; }
                        Text {
                            x: 10px;
                            text: root.pin-active ? root.editing-text
                                : root.pin == ""  ? "(не задан)"
                                :                   "●●●●";
                            color: root.pin-active  ? #e6edf3
                                 : root.pin == ""   ? #484f58
                                 :                    #e6edf3;
                            font-size: 14px; vertical-alignment: center; overflow: elide;
                        }
                        TouchArea {
                            clicked => { root.editing-text = ""; root.pin-active = true; }
                        }
                    }
                }
                Text { text: "Только цифры, до 8 знаков"; color: #3d444d; font-size: 12px; }

                // Кнопка очистить PIN
                if root.pin != "" && !root.pin-active: Rectangle {
                    height: 40px;
                    background: clr-ta.has-hover ? #3d1414 : transparent;
                    border-radius: 8px; border-width: 1px;
                    border-color: clr-ta.has-hover ? #da3633 : #30363d;
                    animate background { duration: 100ms; }
                    Text {
                        text: "Очистить PIN-код";
                        color: #f85149; font-size: 14px;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                    clr-ta := TouchArea { clicked => { root.save-pin(""); } }
                }
            }
        }

        // Виртуальная клавиатура
        if root.pin-active: VirtualKeyboard {
            y: content.height - 258px;
            width: content.width;
            value <=> root.editing-text;
            done => {
                root.save-pin(root.editing-text);
                root.pin-active = false;
            }
            delete-last => { root.editing-delete-last(); }
        }
    }
}
