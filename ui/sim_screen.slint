import { VirtualKeyboard } from "keyboard.slint";

// ── SIM screen ────────────────────────────────────────────────────────────────
export component SimScreen {
    in-out property <string>   msisdn:        "—";
    in-out property <string>   signal:        "—";
    in-out property <string>   reg:           "—";
    in-out property <string>   cpin:          "—";
    in-out property <[string]> whitelist;
    in-out property <string>   editing-text:  "";

    callback whitelist-add(string);
    callback whitelist-remove(int);
    callback editing-delete-last();

    property <bool> add-active: false;

    // ── Header ────────────────────────────────────────────────────
    Rectangle {
        y: 0; height: 56px; background: #161b22;
        HorizontalLayout {
            padding-left: 20px; padding-right: 20px;
            Text {
                text: "SIM-КАРТА"; color: #e6edf3;
                font-size: 20px; font-weight: 700; vertical-alignment: center;
            }
        }
    }

    // ── Content ───────────────────────────────────────────────────
    content := Rectangle {
        y: 56px;
        height: parent.height - 56px;
        clip: true;

        Flickable {
            y: 0; width: parent.width;
            height: root.add-active ? content.height - 258px : content.height;
            interactive: true;
            viewport-width: self.width;
            viewport-height: 500px;

            VerticalLayout {
                padding: 16px; spacing: 12px; alignment: start;

                // ── Блок статуса ──────────────────────────────────
                Text {
                    text: "СТАТУС"; color: #484f58;
                    font-size: 11px; letter-spacing: 0.8px;
                }
                Rectangle {
                    height: 120px;
                    background: #161b22;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: #21262d;

                    VerticalLayout {
                        padding: 12px; spacing: 6px;

                        for row in [
                            { label: "Номер:", value: root.msisdn },
                            { label: "Сигнал:", value: root.signal },
                            { label: "Сеть:", value: root.reg    },
                            { label: "SIM:", value: root.cpin   },
                        ]: HorizontalLayout {
                            height: 20px;
                            Text {
                                text: row.label; color: #8b949e;
                                font-size: 13px; vertical-alignment: center;
                                width: 80px;
                            }
                            Text {
                                text: row.value; color: #e6edf3;
                                font-size: 13px; vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                    }
                }

                // ── Разрешённые номера ────────────────────────────
                Text {
                    text: "РАЗРЕШЁННЫЕ НОМЕРА"; color: #484f58;
                    font-size: 11px; letter-spacing: 0.8px;
                }

                if root.whitelist.length == 0: Text {
                    text: "Список пуст — команды по SMS отключены";
                    color: #3d444d; font-size: 13px;
                }

                for num[idx] in root.whitelist: HorizontalLayout {
                    height: 40px; spacing: 8px;

                    Rectangle {
                        horizontal-stretch: 1;
                        background: #161b22;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: #21262d;
                        Text {
                            x: 12px;
                            text: num; color: #e6edf3;
                            font-size: 14px; vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        width: 40px;
                        background: del-ta.has-hover ? #3d1414 : #161b22;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: del-ta.has-hover ? #da3633 : #21262d;
                        animate background { duration: 100ms; }
                        Text {
                            text: "✕"; color: #f85149;
                            font-size: 16px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        del-ta := TouchArea {
                            clicked => { root.whitelist-remove(idx); }
                        }
                    }
                }

                // ── Поле добавления номера ────────────────────────
                Text {
                    text: "ДОБАВИТЬ НОМЕР"; color: #484f58;
                    font-size: 11px; letter-spacing: 0.8px;
                }
                HorizontalLayout {
                    height: 44px; spacing: 8px;

                    Rectangle {
                        horizontal-stretch: 1;
                        background: #0d1117;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: root.add-active ? #f0883e : #30363d;
                        animate border-color { duration: 100ms; }
                        Text {
                            x: 10px;
                            text: root.add-active ? root.editing-text : "+7...";
                            color: root.add-active ? #e6edf3 : #484f58;
                            font-size: 14px; vertical-alignment: center;
                            overflow: elide;
                        }
                        TouchArea {
                            clicked => {
                                root.editing-text = "";
                                root.add-active = true;
                            }
                        }
                    }

                    Rectangle {
                        width: 120px;
                        background: add-ta.has-hover ? #2ea043 : #238636;
                        border-radius: 6px;
                        animate background { duration: 100ms; }
                        Text {
                            text: "ДОБАВИТЬ"; color: #ffffff;
                            font-size: 13px; font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        add-ta := TouchArea {
                            clicked => {
                                root.whitelist-add(root.editing-text);
                                root.editing-text = "";
                                root.add-active = false;
                            }
                        }
                    }
                }
            }
        }

        // ── Виртуальная клавиатура ────────────────────────────────
        if root.add-active: VirtualKeyboard {
            y: content.height - 258px;
            width: content.width;
            value <=> root.editing-text;
            done => {
                root.whitelist-add(root.editing-text);
                root.editing-text = "";
                root.add-active = false;
            }
            delete-last => { root.editing-delete-last(); }
        }
    }
}
