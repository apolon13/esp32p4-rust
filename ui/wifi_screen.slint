import { VirtualKeyboard } from "keyboard.slint";

export struct NetworkInfo {
    ssid:    string,
    rssi:    int,
    secured: bool,
}

// ── Font glyph coverage ───────────────────────────────────────────────────────
component CyrillicCoverage {
    width: 0; height: 0;
    Text {
        visible: false;
        font-size: 1px;
        text: "абвгдеёжзийклмнопрстуфхцчшщъыьэюяАБВГДЕЁЖЗИЙКЛМНОПРСТУФХЦЧШЩЪЫЬЭЮЯ" +
              "0123456789:.-+!?()[] ●✓×←";
    }
}

// ── Signal strength indicator ─────────────────────────────────────────────────
component SignalBars {
    in property <int> rssi;
    width:  26px;
    height: 20px;

    property <brush> c0: rssi >= -85 ? #4caf50 : #3d444d;
    property <brush> c1: rssi >= -75 ? #4caf50 : #3d444d;
    property <brush> c2: rssi >= -65 ? #4caf50 : #3d444d;
    property <brush> c3: rssi >= -55 ? #4caf50 : #3d444d;

    Rectangle { x:  0px; y: 14px; width: 4px; height:  6px; background: c0; border-radius: 1px; }
    Rectangle { x:  7px; y:  9px; width: 4px; height: 11px; background: c1; border-radius: 1px; }
    Rectangle { x: 14px; y:  4px; width: 4px; height: 16px; background: c2; border-radius: 1px; }
    Rectangle { x: 21px; y:  0px; width: 4px; height: 20px; background: c3; border-radius: 1px; }
}

// ── Indeterminate progress bar ────────────────────────────────────────────────
component ProgressBar {
    in property <bool> running: false;
    height: 3px;

    property <bool> flip: false;
    Timer {
        interval: 550ms;
        running:  root.running;
        triggered => { root.flip = !root.flip; }
    }

    Rectangle {
        background: #21262d;
        clip: true;
        bar := Rectangle {
            height:     3px;
            width:      90px;
            background: #1f6feb;
            x: root.flip ? parent.width - 90px : 0px;
            animate x { duration: 550ms; easing: ease-in-out; }
        }
    }
}

// ── Password field ────────────────────────────────────────────────────────────
component PasswordField {
    in property <string> value;
    in property <bool>   active: false;
    callback tapped();

    height: 48px;

    Rectangle {
        background:    #0d1117;
        border-radius: 8px;
        border-width:  1px;
        border-color:  active ? #1f6feb : #30363d;

        HorizontalLayout {
            padding-left:  14px;
            padding-right: 14px;

            Text {
                text:               value == "" ? "Введите пароль..." : value;
                color:              value == "" ? #484f58 : #e6edf3;
                font-size:          16px;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
        }
    }

    TouchArea { clicked => { root.tapped(); } }
}

// ── Network card ──────────────────────────────────────────────────────────────
// TouchArea is the LAST (topmost) child so it reliably receives pointer events.
// Cards live inside a Flickable for vertical scrolling; the 30 px drag
// threshold in the touch controller prevents jitter from triggering scroll.
component NetworkCard {
    in property <NetworkInfo> data;
    callback clicked();

    Rectangle {
        background:    ta.has-hover ? #1c2128 : #161b22;
        border-radius: 12px;
        border-width:  1px;
        border-color:  ta.has-hover ? #388bfd : #30363d;
        animate background   { duration: 100ms; }
        animate border-color { duration: 100ms; }

        VerticalLayout {
            padding: 12px;
            spacing: 6px;

            Text {
                text:        root.data.ssid;
                color:       #e6edf3;
                font-size:   14px;
                font-weight: 600;
                overflow:    elide;
            }

            HorizontalLayout {
                spacing: 8px;

                SignalBars { rssi: root.data.rssi; }

                Text {
                    text:               root.data.rssi + " dBm";
                    color:              #8b949e;
                    font-size:          12px;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                Text {
                    text:               root.data.secured ? "🔒 WPA" : "Открытая";
                    color:              root.data.secured ? #f0883e : #3fb950;
                    font-size:          12px;
                    vertical-alignment: center;
                }
            }
        }
    }

    ta := TouchArea { clicked => { root.clicked(); } }
}

// ── Main WiFi screen ──────────────────────────────────────────────────────────
export component WifiScreen {
    in-out property <[NetworkInfo]> networks;
    in-out property <int>           selected-index: -1;
    in-out property <string>        status: "Инициализация Wi-Fi...";
    in-out property <string>        password;
    in-out property <bool>          ready: false;
    in-out property <bool>          scanning: false;
    in-out property <bool>          connecting: false;
    in-out property <bool>          is-connected: false;
    in-out property <string>        connected-ssid: "";
    in-out property <string>        connected-ip: "";

    callback scan-requested();
    callback connect-requested(string, string);
    callback cancel-connect();
    callback password-delete-last();

    property <bool> keyboard-visible: false;
    property <bool> show-form: root.selected-index >= 0;
    property <length> ptr-h: 50px;
    property <bool> ptr-inited: false;
    property <bool> scan-was-active: false;

    CyrillicCoverage {}

    // Pull-to-refresh viewport management
    Timer {
        interval: 10ms;
        running: !root.ptr-inited;
        triggered => {
            grid-flick.viewport-y = -root.ptr-h;
            root.ptr-inited = true;
        }
    }

    Timer {
        interval: 100ms;
        running: root.ptr-inited;
        triggered => {
            if root.scan-was-active && !root.scanning {
                grid-flick.viewport-y = -root.ptr-h;
            }
            root.scan-was-active = root.scanning;
            if !root.scanning && root.ready && !root.connecting && !root.show-form {
                if grid-flick.viewport-y > -(root.ptr-h / 3) {
                    root.scanning = true;
                    root.scan-requested();
                }
            }
        }
    }

    Rectangle {
        clip: true;

        // ══════════════════════════════════════════════════════════════
        // PAGE 1 — Network grid  (selected-index < 0)
        // ══════════════════════════════════════════════════════════════
        Rectangle {
            x: root.show-form ? -parent.width : 0px;
            width: parent.width;
            height: parent.height;
            background: #0d1117;
            animate x { duration: 250ms; easing: ease-in-out; }

        // ── Header ────────────────────────────────────────────────
        Rectangle {
            y:          0;
            height:     56px;
            background: #161b22;

            HorizontalLayout {
                padding-left:  20px;
                padding-right: 20px;
                spacing:       12px;

                Text {
                    text:               "Wi-Fi";
                    color:              #e6edf3;
                    font-size:          20px;
                    font-weight:        700;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                if root.is-connected: Rectangle {
                    width:         200px;
                    height:        46px;
                    background:    #0d2818;
                    border-radius: 6px;
                    border-width:  1px;
                    border-color:  #238636;

                    VerticalLayout {
                        alignment: center;
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 2px;

                        Text {
                            text:                 "● " + root.connected-ssid;
                            color:                #3fb950;
                            font-size:            12px;
                            horizontal-alignment: center;
                            overflow:             elide;
                        }
                        if root.connected-ip != "": Text {
                            text:                 root.connected-ip;
                            color:                #7ee787;
                            font-size:            10px;
                            horizontal-alignment: center;
                        }
                    }
                }

                Rectangle {
                    property <bool> can-scan: root.ready && !root.scanning && !root.connecting;
                    width:         160px;
                    background:    root.scanning ? #161b22
                                 : !can-scan    ? #161b22
                                 : scan-ta.has-hover ? #2d333b : #21262d;
                    border-radius: 6px;
                    border-width:  1px;
                    border-color:  root.scanning ? #1f6feb
                                 : !can-scan    ? #21262d
                                 : #30363d;
                    animate background   { duration: 150ms; }
                    animate border-color { duration: 150ms; }

                    Text {
                        text:                 !root.ready   ? "Инициализация..."
                                            : root.scanning ? "Поиск..."
                                            : "Сканировать";
                        color:                !root.ready   ? #484f58
                                            : root.scanning ? #1f6feb
                                            : #e6edf3;
                        font-size:            14px;
                        horizontal-alignment: center;
                        vertical-alignment:   center;
                        animate color { duration: 150ms; }
                    }

                    scan-ta := TouchArea {
                        enabled: parent.can-scan;
                        clicked => {
                            root.scanning = true;
                            root.scan-requested();
                        }
                    }
                }
            }
        }

        // ── Scan progress bar ──────────────────────────────────────
        if root.scanning: ProgressBar {
            y:       56px;
            width:   root.width;
            running: true;
        }

        // ── Status bar ─────────────────────────────────────────────
        Rectangle {
            y:          root.height - 40px;
            height:     40px;
            background: #161b22;

            HorizontalLayout {
                padding-left:  20px;
                padding-right: 20px;

                Text {
                    text:               root.status;
                    color:              (root.connecting || root.scanning) ? #58a6ff : #8b949e;
                    font-size:          13px;
                    vertical-alignment: center;
                    animate color { duration: 200ms; }
                }
            }
        }

        // ── Scrollable network card grid ─────────────────────────────
        Rectangle {
            y:          59px;
            height:     root.height - 59px - 40px;
            background: #0d1117;
            clip:       true;

            // Scrollable card grid (behind overlays)
            grid-flick := Flickable {
                interactive: !root.scanning && root.ready && !root.connecting;
                viewport-width:  self.width;
                property <length> pad:    12px;
                property <length> gap:    10px;
                property <length> card-w: (self.width - pad * 2 - gap * 2) / 3;
                property <length> card-h: 90px;
                property <int>    num-rows: root.networks.length > 0
                    ? floor((root.networks.length - 1) / 3) + 1
                    : 0;
                property <length> grid-h: num-rows > 0
                    ? num-rows * (card-h + gap) - gap + pad * 2
                    : 0px;

                viewport-height: root.ptr-h
                    + (grid-h > self.height ? grid-h : self.height);

                Rectangle {
                    y: 0;
                    height: root.ptr-h;
                    width: parent.viewport-width;

                    Text {
                        text: root.scanning ? "Обновление..." : "↓ Обновить";
                        color: #484f58;
                        font-size: 13px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                for net[idx] in root.networks: NetworkCard {
                    data:   net;
                    x:      mod(idx, 3) * (card-w + gap) + pad;
                    y:      root.ptr-h + floor(idx / 3) * (card-h + gap) + pad;
                    width:  card-w;
                    height: card-h;
                    clicked => {
                        if net.secured {
                            root.selected-index   = idx;
                            root.password         = "";
                            root.keyboard-visible = false;
                        } else {
                            root.connect-requested(net.ssid, "");
                        }
                    }
                }
            }

            // Empty state (drawn on top of Flickable)
            if root.networks.length == 0 && !root.scanning: Text {
                text:                 root.connecting ? "Автоподключение..."
                                                 : root.ready ? "Нажмите Сканировать"
                                                 : "Инициализация Wi-Fi...";
                color:                root.connecting ? #58a6ff : #484f58;
                font-size:            14px;
                horizontal-alignment: center;
                vertical-alignment:   center;
            }

            // Scanning overlay (drawn on top of Flickable)
            if root.scanning: VerticalLayout {
                alignment: center;
                spacing:   16px;
                Text {
                    text:                 "Поиск сетей...";
                    color:                #8b949e;
                    font-size:            14px;
                    horizontal-alignment: center;
                }
                HorizontalLayout {
                    alignment: center;
                    spacing:   8px;
                    dot1 := Rectangle {
                        width: 10px; height: 10px; border-radius: 5px; background: #1f6feb;
                        property <bool> f: false;
                        opacity: f ? 1.0 : 0.2;
                        animate opacity { duration: 450ms; easing: ease-in-out; }
                        Timer { interval: 450ms; running: root.scanning; triggered => { dot1.f = !dot1.f; } }
                    }
                    dot2 := Rectangle {
                        width: 10px; height: 10px; border-radius: 5px; background: #1f6feb;
                        property <bool> f: false;
                        opacity: f ? 1.0 : 0.2;
                        animate opacity { duration: 450ms; delay: 150ms; easing: ease-in-out; }
                        Timer { interval: 450ms; running: root.scanning; triggered => { dot2.f = !dot2.f; } }
                    }
                    dot3 := Rectangle {
                        width: 10px; height: 10px; border-radius: 5px; background: #1f6feb;
                        property <bool> f: false;
                        opacity: f ? 1.0 : 0.2;
                        animate opacity { duration: 450ms; delay: 300ms; easing: ease-in-out; }
                        Timer { interval: 450ms; running: root.scanning; triggered => { dot3.f = !dot3.f; } }
                    }
                }
            }
        }
    }

        // ══════════════════════════════════════════════════════════════
        // PAGE 2 — Connection form  (selected-index >= 0)
        // ══════════════════════════════════════════════════════════════
        Rectangle {
            x: root.show-form ? 0px : parent.width;
            width: parent.width;
            height: parent.height;
            background: #0d1117;
            animate x { duration: 250ms; easing: ease-in-out; }

        // ── Header with back button ────────────────────────────────
        Rectangle {
            y:          0;
            height:     56px;
            background: #161b22;

            HorizontalLayout {
                padding-left:  8px;
                padding-right: 20px;
                spacing:       4px;

                Rectangle {
                    width:         130px;
                    background:    back-ta.has-hover ? #21262d : transparent;
                    border-radius: 6px;
                    animate background { duration: 100ms; }

                    Text {
                        x:                  12px;
                        text:               "← Назад";
                        color:              #58a6ff;
                        font-size:          15px;
                        vertical-alignment: center;
                    }

                    back-ta := TouchArea {
                        clicked => {
                            root.selected-index   = -1;
                            root.keyboard-visible = false;
                        }
                    }
                }

                Text {
                    text:               root.selected-index >= 0
                                            ? root.networks[root.selected-index].ssid : "";
                    color:              #e6edf3;
                    font-size:          18px;
                    font-weight:        700;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow:           elide;
                }

                if root.is-connected: Text {
                    text:               root.connected-ip != ""
                                            ? "● " + root.connected-ssid + " • " + root.connected-ip
                                            : "● " + root.connected-ssid;
                    color:              #3fb950;
                    font-size:          12px;
                    vertical-alignment: center;
                }
            }
        }

        // ── Status bar ─────────────────────────────────────────────
        Rectangle {
            y:          root.height - 40px;
            height:     40px;
            background: #161b22;

            HorizontalLayout {
                padding-left:  20px;
                padding-right: 20px;

                Text {
                    text:               root.status;
                    color:              (root.connecting || root.scanning) ? #58a6ff : #8b949e;
                    font-size:          13px;
                    vertical-alignment: center;
                    animate color { duration: 200ms; }
                }
            }
        }

        // ── Connection form ────────────────────────────────────────
        Rectangle {
            y:          56px;
            height:     root.height - 56px - 40px;
            background: #0d1117;
            clip:       true;

            VerticalLayout {
                padding:   24px;
                spacing:   16px;
                alignment: start;

                // Network summary card
                Rectangle {
                    height:        76px;
                    background:    #161b22;
                    border-radius: 10px;
                    border-width:  1px;
                    border-color:  #30363d;

                    HorizontalLayout {
                        padding: 16px;
                        spacing: 12px;

                        VerticalLayout {
                            alignment:          center;
                            spacing:            4px;
                            horizontal-stretch: 1;

                            Text {
                                text:        root.selected-index >= 0
                                                 ? root.networks[root.selected-index].ssid : "";
                                color:       #e6edf3;
                                font-size:   18px;
                                font-weight: 700;
                                overflow:    elide;
                            }
                            Text {
                                text:      root.selected-index >= 0
                                               && root.networks[root.selected-index].secured
                                               ? "Защищённая сеть (WPA/WPA2)"
                                               : "Открытая сеть";
                                color:     root.selected-index >= 0
                                               && root.networks[root.selected-index].secured
                                               ? #f0883e : #3fb950;
                                font-size: 12px;
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            spacing:   4px;

                            SignalBars {
                                rssi: root.selected-index >= 0
                                          ? root.networks[root.selected-index].rssi : -100;
                            }
                            Text {
                                text:                 root.selected-index >= 0
                                                          ? root.networks[root.selected-index].rssi + " dBm"
                                                          : "";
                                color:                #8b949e;
                                font-size:            11px;
                                horizontal-alignment: center;
                            }
                        }
                    }
                }

                Text {
                    text:      "Пароль:";
                    color:     #8b949e;
                    font-size: 13px;
                }

                PasswordField {
                    value:  root.password;
                    active: root.keyboard-visible;
                    tapped => { root.keyboard-visible = !root.keyboard-visible; }
                }

                if root.keyboard-visible: VirtualKeyboard {
                    value <=> root.password;
                    done => { root.keyboard-visible = false; }
                    delete-last => { root.password-delete-last(); }
                }

                if !root.keyboard-visible && !root.connecting: Rectangle {
                    height:        56px;
                    background:    conn-ta.has-hover ? #2ea043 : #238636;
                    border-radius: 10px;
                    animate background { duration: 100ms; }

                    Text {
                        text:                 "Подключиться";
                        color:                #ffffff;
                        font-size:            16px;
                        font-weight:          700;
                        horizontal-alignment: center;
                        vertical-alignment:   center;
                    }

                    conn-ta := TouchArea {
                        clicked => {
                            root.connecting       = true;
                            root.keyboard-visible = false;
                            root.connect-requested(
                                root.selected-index >= 0
                                    ? root.networks[root.selected-index].ssid : "",
                                root.password
                            );
                        }
                    }
                }

                if !root.keyboard-visible && root.connecting: Rectangle {
                    height:        56px;
                    background:    cancel-ta.has-hover ? #5a1d1d : #3d1414;
                    border-radius: 10px;
                    border-width:  1px;
                    border-color:  #da3633;
                    animate background { duration: 100ms; }

                    Text {
                        text:                 "Отменить подключение";
                        color:                #f85149;
                        font-size:            16px;
                        font-weight:          700;
                        horizontal-alignment: center;
                        vertical-alignment:   center;
                    }

                    cancel-ta := TouchArea {
                        clicked => {
                            root.cancel-connect();
                        }
                    }
                }
            }
        }
    }
    }
}
